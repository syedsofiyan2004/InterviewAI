# Bedrock Inference Profile ARNs (APAC/ap-south-1)
# Create a local .env file in this directory and paste your real ARNs there.
# Do NOT commit your real .env file.
BEDROCK_SONNET_PROFILE_ARN=arn:aws:bedrock:ap-south-1:XXXXXX:inference-profile/apac.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_HAIKU_PROFILE_ARN=arn:aws:bedrock:ap-south-1:XXXXXX:inference-profile/apac.anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_NOVA_PROFILE_ARN=arn:aws:bedrock:ap-south-1:XXXXXX:inference-profile/apac.amazon.nova-pro-v1:0

# Safety Gate: Set to true only if you want to allow base model fallbacks when profiles are missing
ALLOW_BEDROCK_BASE_MODEL_FALLBACK=false

# Environment Configuration
NODE_ENV=dev
AWS_REGION=ap-south-1
